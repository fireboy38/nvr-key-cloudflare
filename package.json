{
  "name": "nvr-key-cloudflare",
  "version": "1.0.0",
  "description": "海康录像下载器 - 注册机 Web 管理台 (Cloudflare Workers 版)",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "bootstrap": "node scripts/bootstrap.mjs",
    "predeploy": "node scripts/bootstrap.mjs",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:init": "wrangler d1 execute nvr-key-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute nvr-key-db --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.78.0"
  }
}
